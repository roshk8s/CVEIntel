# AI Provider: openai | bedrock | local
CVEINTEL_PROVIDER=

# API key for OpenAI-compatible providers
CVEINTEL_API_KEY=

# Model name or ID (e.g. gpt-4, anthropic.claude-v2)
CVEINTEL_MODEL=

# Endpoint URL for local LLM
CVEINTEL_LOCAL_ENDPOINT=

# AWS region for Bedrock and S3
AWS_DEFAULT_REGION=us-east-1
